    <h1 class="display-5 fw-bold mb-3" data-i18n="about_title">About Sochi Birds</h1>
    <p class="lead text-muted mb-0" data-i18n="about_subtitle">
      Real-time bird sound identification for Sochi and the Black Sea coast, running entirely in your web browser.
    </p>
  </div>
